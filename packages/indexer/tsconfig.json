{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["ponder.config.ts", "ponder.schema.ts", "src/**/*.ts", "abis/**/*.ts", "ponder-env.d.ts"]
}
