# Backend services. REQUIRED in production — without them the deployed app calls
# localhost and every request fails CORS. The /status page (#/status) shows which are up.
VITE_API_URL=http://localhost:8787
VITE_INDEXER_URL=http://localhost:42069
# VITE_RPC_URL=https://your-base-sepolia-rpc

# Optional: enable real IPFS uploads for proposals/deliverables/evidence.
# Without these, attachments are stored as content hashes (no gateway link).
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
